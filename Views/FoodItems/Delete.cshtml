@model FoodOrderSystem.Models.FoodItem

<div class="container mt-4">

    <h2 class="text-danger">
        Delete Food
    </h2>

    <hr />

    <h4>
        Are you sure you want to delete this?
    </h4>

    <div class="card p-4 mt-3">

        <img src="@Model.ImageUrl"
             width="120"
             height="120"
             class="mb-3" />

        <h4>@Model.FoodName</h4>

        <h5>₹ @Model.Price</h5>

        <p>@Model.Description</p>

    </div>

    <form method="post">

        <input type="hidden"
               asp-for="FoodId" />

        <button type="submit"
                class="btn btn-danger">

            Delete

        </button>

        <a asp-action="Index"
           class="btn btn-secondary">

            Cancel

        </a>

    </form>

</div>