    <!-- Food Menu -->

    <h2 id="foodmenu"
        class="text-center mb-5 fw-bold">

        Our Food Menu

    </h2>
    <!-- Category Search -->

    <form method="get" asp-controller="Home" asp-action="Index" asp-fragment="foodmenu">

        <div class="row mb-4">

            <div class="col-md-6 mx-auto d-flex gap-2">

                <select name="category"
                        class="form-control">

                    <option value="">
                        -- Select Category --
                    </option>

                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.CategoryName">

                            @cat.CategoryName

                        </option>
                    }

                </select>

                <button type="submit"
                        class="btn btn-dark">

                    Search

                </button>

            </div>

        </div>

    </form>


    <div class="text-center mb-4">

        @foreach (var cat in ViewBag.Categories)
        {
            <a asp-controller="Home"
               asp-action="Index"
               asp-route-category="@cat.CategoryName"
               asp-fragment="foodmenu"
               class="btn btn-outline-primary m-1">

                @cat.CategoryName

            </a>
        }

    </div>

    <!-- Food Cards -->

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">

                <div class="card shadow-lg h-100 border-0">

                    <img src="@item.ImageUrl"
                         class="card-img-top"
                         height="220"
                         style="object-fit:cover;" />


                    <div class="card-body">

                        <h5 class="card-title fw-bold">
                            @item.FoodName
                        </h5>

                        <p class="card-text text-muted">

                            @item.Description

                        </p>

                        <h5 class="text-success">

                            ₹ @item.Price

                        </h5>

                    </div>

                    <div class="card-footer bg-white border-0">

                        <a asp-controller="Cart"
                           asp-action="AddToCart"
                           asp-route-id="@item.FoodId"
                           class="btn btn-success w-100">

                            Add To Cart

                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

